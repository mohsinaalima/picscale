model Image {
  id        String   @id @default(uuid())
  url       String
  category  String?
  userId    String   

  likes     Like[]   
  saves     Save[]   

  createdAt DateTime @default(now())
}

model Like {
  id      String @id @default(uuid())

  userId  String // Clerk ID of the person who liked

  imageId String
  image   Image  @relation(fields: [imageId], references: [id])

  @@unique([userId, imageId]) 
}

model Save {
  id      String @id @default(uuid())

  userId  String 

  imageId String
  image   Image  @relation(fields: [imageId], references: [id])

  @@unique([userId, imageId]) 
}

model Follow {
  id          String @id @default(uuid())

  followerId  String 
  followingId String 

  @@unique([followerId, followingId])
}