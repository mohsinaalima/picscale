model Image {
  id        String   @id @default(uuid())
  url       String
  category  String?
  userId    String   // Owner of the post
  likes     Like[]   // Relation to likes
  saves     Save[]   // Relation to saves
  createdAt DateTime @default(now())
}

model Like {
  id      String @id @default(uuid())
  userId  String // Clerk ID of the person who liked
  imageId String
  image   Image  @relation(fields: [imageId], references: [id])

  @@unique([userId, imageId]) // Prevent liking a post twice
}

model Save {
  id      String @id @default(uuid())
  userId  String // Clerk ID of the person who saved
  imageId String
  image   Image  @relation(fields: [imageId], references: [id])

  @@unique([userId, imageId]) // Prevent saving twice
}

model Follow {
  id          String @id @default(uuid())
  followerId  String // Clerk ID of person following
  followingId String // Clerk ID of person being followed

  @@unique([followerId, followingId])
}