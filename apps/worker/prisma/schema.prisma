datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// apps/api/prisma/schema.prisma AND apps/worker/prisma/schema.prisma
model Image {
  id        String   @id @default(uuid())
  url       String   // The original Cloudinary URL
  thumbUrl  String?  // The processed thumbnail URL
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}