generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Image {
  id       String  @id @default(uuid())
  url      String
  category String? @default("Abstract")
  status   String  @default("PENDING")
  userId   String
  likes    Like[]
  saves    Save[]

  createdAt DateTime @default(now())
}

model Like {
  id String @id @default(uuid())

  userId String // Clerk ID of the person who liked

  imageId String
  image   Image  @relation(fields: [imageId], references: [id])

  @@unique([userId, imageId])
}

model Save {
  id String @id @default(uuid())

  userId String

  imageId String
  image   Image  @relation(fields: [imageId], references: [id])

  @@unique([userId, imageId])
}

model Follow {
  id String @id @default(uuid())

  followerId  String
  followingId String

  @@unique([followerId, followingId])
}

model Chat {
  id        String    @id @default(uuid())
  userOneId String // Chat shuru karne wala (Clerk User ID)
  userTwoId String // Receive karne wala (Clerk User ID)
  createdAt DateTime  @default(now())
  messages  Message[]

  @@unique([userOneId, userTwoId]) // Taaki do creators ke beech double rooms na banein
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String // Jisne text bheja uski Clerk ID
  text      String
  createdAt DateTime @default(now())
}
